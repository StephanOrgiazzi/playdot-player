{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PLAY.",
  "mainBinaryName": "playdot-player",
  "version": "0.9.0",
  "identifier": "com.playdot.player",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "PLAY.",
        "width": 1400,
        "height": 840,
        "minWidth": 800,
        "minHeight": 500,
        "visible": false,
        "decorations": false,
        "resizable": true,
        "transparent": true,
        "backgroundColor": "#000000",
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "fileAssociations": [
      {
        "name": "PLAY.Video",
        "description": "PLAY. Video File",
        "ext": [
          "3g2",
          "3gp",
          "asf",
          "avi",
          "drc",
          "f4v",
          "flv",
          "m2ts",
          "m2v",
          "m4v",
          "mkv",
          "mov",
          "mp4",
          "mpeg",
          "mpg",
          "mxf",
          "mts",
          "ogm",
          "ogv",
          "qt",
          "rm",
          "rmvb",
          "ts",
          "vob",
          "webm",
          "wmv"
        ]
      }
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico"
      }
    },
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.ico"],
    "resources": ["lib/**/*", "../shaders/**/*"]
  }
}
