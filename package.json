{
  "name": "playdot-player",
  "version": "0.15.0",
  "private": true,
  "workspaces": [
    "website"
  ],
  "type": "module",
  "scripts": {
    "dev": "vite",
    "app:dev": "bun run setup-lib && bun run tauri:dev",
    "build": "tsc -b && vite build",
    "lint": "oxlint -c ./.oxlintrc.json .",
    "format": "oxfmt -c ./.oxfmtrc.json --check .",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "setup-lib": "bun ./scripts/setup-lib.mjs",
    "release:win": "bun run setup-lib && tauri build --bundles nsis",
    "release:artifacts": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/release-artifacts.ps1",
    "release": "bun run release:win && bun run release:artifacts"
  },
  "dependencies": {
    "@tauri-apps/api": "2.11.0",
    "@tauri-apps/plugin-dialog": "2.7.1",
    "@tauri-apps/plugin-log": "2.8.0",
    "effect": "4.0.0-beta.98",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "7z-wasm": "^1.2.0",
    "@tauri-apps/cli": "2.11.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "oxfmt": "^0.47.0",
    "oxlint": "1.75.0",
    "oxlint-tsgolint": "7.0.2001",
    "typescript": "^7.0.2",
    "vite": "^8.0.10"
  },
  "packageManager": "bun@1.3.10"
}
